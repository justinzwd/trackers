{
  "name": "trackers-worker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create trackers-db",
    "db:init": "wrangler d1 execute trackers-db --file=../schema.sql",
    "db:migrate": "wrangler d1 execute trackers-db --file=../schema.sql --remote"
  },
  "dependencies": {
    "hono": "^4.1.0"
  },
  "devDependencies": {
    "wrangler": "^3.34.0"
  }
}